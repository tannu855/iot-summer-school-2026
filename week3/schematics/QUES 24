#include <DHT.h>

#define dhtpin 2
#define dhttype DHT22
#define trig 4
#define echo 5
int ldr = A0 ;
DHT dht(dhtpin , dhttype);



void setup() {
  Serial.begin(9600);
  dht.begin();
  pinMode(dhtpin , INPUT);
  pinMode(trig , OUTPUT);
  pinMode(echo , INPUT);
  pinMode(ldr , INPUT);
  Serial.println("=== SENSOR LOG ===");


}

void loop() {

//DHT22
  float h = dht.readHumidity();
  float c = dht.readTemperature();

  if (isnan(h) || isnan(c) ){
    return ;
  }

  //UltraSonic Sensor
  digitalWrite(trig , LOW);
  delayMicroseconds(2);
  digitalWrite(trig , HIGH);
  delayMicroseconds(10);
  digitalWrite(trig , LOW);

  long dur = pulseIn(echo , HIGH);
  int dis = dur*0.034/2 ;


  
  unsigned int timestamp = millis() ;


  //LDR

  int raw = analogRead(ldr);
  int per = map(raw , 0 , 1023 , 100 , 0);




  // printing
  
  Serial.print("Time      : ");
  Serial.print(timestamp);
  
  Serial.print("\n");
  
  Serial.print("Temp  : ");  
  Serial.print(c);
  Serial.print(" | Humidity  : ");
  Serial.print(h);
  
  Serial.print("\n");

  Serial.print("Light     : ");
  Serial.print(per);
  Serial.print("% (BRIGHT)");

  Serial.print("\n");

  Serial.print("Distance  : ");
  Serial.print(dis);

  Serial.print("\n");
  

  Serial.print("================== ");
  Serial.print("\n");


  delay(5000);





}
