
int red = 2;
int yellow = 3;
int green = 4;
int button = 7;

void setup() {
  pinMode(red, OUTPUT);
  pinMode(yellow, OUTPUT);
  pinMode(green, OUTPUT);
  pinMode(button, INPUT_PULLUP); 
  Serial.begin(9600);
}

bool waitAndCheckButton(unsigned long milliseconds) {
  for (unsigned long i = 0; i < milliseconds; i++) {
     if (digitalRead(button) == LOW) {
        Serial.println("Button Pressed");
      return true; 
    }
    delay(1);
  }
  return false; 
}

void loop() {
  
  digitalWrite(red, HIGH);

    Serial.println("RED");
  if (waitAndCheckButton(5000)) {
    triggerPedestrianRed();
    return; 
  }
  digitalWrite(red, LOW);
  digitalWrite(yellow, HIGH);
  Serial.println("YELLOW");
  if (waitAndCheckButton(2000)) {
    triggerPedestrianRed();
    return; 
  }
  digitalWrite(yellow, LOW);
  digitalWrite(green, HIGH);
  Serial.println("GREEN");
  if (waitAndCheckButton(4000)) {
    triggerPedestrianRed();
    return; 
  }
  digitalWrite(green, LOW);
}

void triggerPedestrianRed() {
  digitalWrite(yellow, LOW);
  digitalWrite(green, LOW);
  
  digitalWrite(red, HIGH);
  Serial.println("RED");
  delay(8000); 
  digitalWrite(red, LOW);
}
